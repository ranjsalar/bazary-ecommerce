# Copy to .env and fill in values.
# PostgreSQL — local dev container (docker compose up -d):
DATABASE_URL="postgresql://postgres:devpassword@localhost:5433/bazary"
# Production: point at your managed PostgreSQL instance, e.g.
# DATABASE_URL="postgresql://user:password@host:5432/bazary?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
